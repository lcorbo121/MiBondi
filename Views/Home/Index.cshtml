@using Microsoft.Extensions.Configuration
@inject IConfiguration Config
@{
    Layout = null;
    var wmsUrl = Config["Mapa:WmsUrl"];
    var wmsLayer = Config["Mapa:WmsLayer"];
    var centroLat = Config["Mapa:CentroLat"];
    var centroLng = Config["Mapa:CentroLng"];
    var zoom = Config["Mapa:Zoom"];
    var refresco = Config["Mapa:RefrescoSegundos"];
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Bus en Vivo · Montevideo</title>

    <script>
        // Quita el branding/publicidad que somee inyecta en el plan gratuito.
        // (Solo elimina nodos de somee; no toca prototipos para no romper el resto.)
        (function () {
            const SEL = 'center, a[href*="somee.com"], script[src*="somee"], script[src*="ads.mgmt"], ' +
                        'iframe[src*="somee"], iframe[src*="ads.mgmt"], [id*="WholeInsert"], [class*="WholeInsert"]';
            // divs legítimos de la app (contenedores de nivel raíz que NO hay que borrar)
            const PROPIOS = new Set(['map', 'error', 'leyenda', 'topbar', 'sheet']);
            const limpiar = () => {
                try {
                    document.querySelectorAll(SEL).forEach(el => el.remove());
                    // La barra de publicidad de somee es un <div> fixed con z-index máximo.
                    document.querySelectorAll('[style*="2147483647"]').forEach(el => el.remove());
                    // Cualquier <div> pegado directo al <body> que no sea de la app
                    // (la barra de ads y su espaciador de 65px no tienen id ni clase).
                    if (document.body) {
                        [...document.body.children].forEach(el => {
                            if (el.tagName === 'DIV' && !PROPIOS.has(el.id)) el.remove();
                        });
                    }
                } catch (_) { }
            };
            try {
                new MutationObserver(limpiar).observe(document.documentElement, { childList: true, subtree: true });
            } catch (_) { }
            document.addEventListener('DOMContentLoaded', limpiar);
            window.addEventListener('load', limpiar);
        })();
    </script>

    <link rel="stylesheet"
          href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
    <style>
        :root {
            /* Paleta tipo iOS oscuro: negro OLED + materiales translúcidos (vibrancy) */
            --bg: #000;
            --panel: #1c1c1e;                       /* systemGray6 oscuro */
            --txt: #f5f5f7;                          /* label */
            --muted: rgba(235, 235, 245, .6);       /* secondaryLabel */
            --accent: #ffb000;                       /* tinte de marca (en vivo) */
            --accent-ink: #2a1c00;                   /* texto sobre ámbar */
            --accent-2: #0a84ff;                     /* systemBlue (oscuro) */
            --line: rgba(255, 255, 255, .12);        /* separador hairline */
            --mat: rgba(28, 28, 30, .68);            /* material grueso */
            --mat-blur: saturate(180%) blur(30px);   /* vibrancy de Apple */
            --fill-2: rgba(118, 118, 128, .24);      /* relleno secundario iOS */
            --fill-2-press: rgba(118, 118, 128, .4);
            --radius: 13px;
            --radius-lg: 22px;
            --shadow: 0 10px 40px rgba(0, 0, 0, .4);
            --hi: inset 0 .5px 0 rgba(255, 255, 255, .14);   /* brillo superior del material */
            --sheet-h: 150px;          /* alto real de la hoja inferior (lo publica el JS) */
        }
        * { box-sizing: border-box; }
        html { height: 100%; }
        body {
            margin: 0;
            height: 100vh;
            height: 100dvh;            /* respeta la barra dinámica de Safari en iOS */
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, "Segoe UI", Roboto, sans-serif;
            background: var(--bg);
            color: var(--txt);
            overflow: hidden;          /* solo el mapa se desplaza, no la página */
            -webkit-text-size-adjust: 100%;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            letter-spacing: -.01em;
        }

        /* ===== El mapa es el héroe: ocupa toda la pantalla, debajo de la UI ===== */
        #map { position: fixed; inset: 0; z-index: 0; }

        /* Empuja los controles de Leaflet por debajo del buscador y por encima de la hoja */
        .leaflet-top { top: calc(64px + env(safe-area-inset-top)); }
        .leaflet-bottom { bottom: calc(var(--sheet-h) + 10px + env(safe-area-inset-bottom)); }
        .leaflet-control-attribution {
            font-size: 10px;
            background: rgba(14, 17, 23, .7) !important;
            color: var(--muted) !important;
        }
        .leaflet-control-attribution a { color: var(--muted) !important; }

        /* ===== Buscador flotante (arriba, tipo "glass") ===== */
        .topbar {
            position: fixed; z-index: 1000;
            top: calc(10px + env(safe-area-inset-top));
            left: calc(10px + env(safe-area-inset-left));
            right: calc(10px + env(safe-area-inset-right));
            max-width: 520px; margin: 0 auto;
        }
        .searchbar {
            display: flex; align-items: center; gap: 8px;
            background: var(--mat);
            backdrop-filter: var(--mat-blur); -webkit-backdrop-filter: var(--mat-blur);
            border: .5px solid var(--line); border-radius: var(--radius);
            padding: 5px 5px 5px 14px;
            box-shadow: var(--shadow), var(--hi);
        }
        .searchbar .lupa { color: var(--muted); flex: 0 0 auto; font-size: 1rem; display: flex; }
        .searchbar input {
            flex: 1 1 auto; min-width: 0;
            background: transparent; color: var(--txt); border: 0; outline: none;
            padding: 10px 0; font-size: 17px;     /* tamaño de cuerpo iOS; >=16px evita el zoom de iOS */
            letter-spacing: -.01em;
        }
        .searchbar input::placeholder { color: var(--muted); }
        #btnBuscar {
            flex: 0 0 auto;
            background: var(--accent); color: var(--accent-ink); border: 0;
            border-radius: 10px; padding: 0 16px; height: 38px;
            font-weight: 600; font-size: .95rem; letter-spacing: -.01em;
            cursor: pointer;
            transition: transform .12s ease, filter .12s ease;
        }
        #btnBuscar:hover { filter: brightness(1.06); }
        #btnBuscar:active { transform: scale(.96); }

        /* Botón × para limpiar el texto del buscador (estilo iOS, aparece con texto) */
        .clear {
            flex: 0 0 auto; display: flex; align-items: center; justify-content: center;
            width: 22px; height: 22px; padding: 0; margin: 0 2px;
            background: transparent; border: 0; cursor: pointer;
            color: rgba(235, 235, 245, .35);
        }
        .clear[hidden] { display: none; }
        .clear svg { width: 20px; height: 20px; display: block; }
        .clear:hover { color: rgba(235, 235, 245, .55); }
        .clear:active { transform: scale(.9); }

        /* Combobox: desplegable de sugerencias bajo el buscador */
        .buscador { position: relative; }
        .sugerencias {
            position: absolute; top: calc(100% + 8px); left: 0; right: 0;
            background: var(--mat);
            backdrop-filter: var(--mat-blur); -webkit-backdrop-filter: var(--mat-blur);
            border: .5px solid var(--line); border-radius: var(--radius);
            max-height: 46vh; overflow-y: auto; z-index: 2000; display: none;
            box-shadow: var(--shadow), var(--hi);
            -webkit-overflow-scrolling: touch;
        }
        .sugerencias.abierto { display: block; }
        .sug-item {
            padding: 12px 14px; cursor: pointer; font-size: .98rem;
            border-bottom: .5px solid var(--line);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .sug-item:last-child { border-bottom: 0; }
        .sug-item:hover, .sug-item.activo { background: var(--fill-2); }
        .sug-item .num { color: var(--accent); font-weight: 600; margin-right: 8px; font-variant-numeric: tabular-nums; }
        .sub-tag {
            display: inline-block; margin-left: 6px; padding: 0 6px;
            font-size: .72rem; font-weight: 600; border-radius: 6px;
            background: var(--accent-2); color: #fff; vertical-align: middle;
        }

        /* ===== Banner de error flotante ===== */
        #error {
            position: fixed; z-index: 1500;
            top: calc(72px + env(safe-area-inset-top));
            left: calc(10px + env(safe-area-inset-left));
            right: calc(10px + env(safe-area-inset-right));
            max-width: 520px; margin: 0 auto;
            display: none; background: rgba(120, 30, 30, .82); color: #ffd9d6;
            backdrop-filter: var(--mat-blur); -webkit-backdrop-filter: var(--mat-blur);
            padding: 11px 15px; font-size: .88rem;
            border: .5px solid rgba(255, 120, 110, .35); border-radius: var(--radius);
            box-shadow: var(--shadow), var(--hi);
        }

        /* ===== FAB: centrar en mi ubicación ===== */
        .fab {
            position: fixed; z-index: 1100;
            right: calc(14px + env(safe-area-inset-right));
            bottom: calc(var(--sheet-h) + 16px + env(safe-area-inset-bottom));
            width: 46px; height: 46px; border-radius: 50%;
            background: var(--mat); color: var(--accent-2); border: .5px solid var(--line);
            backdrop-filter: var(--mat-blur); -webkit-backdrop-filter: var(--mat-blur);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; box-shadow: var(--shadow), var(--hi);
            transition: bottom .25s ease, transform .12s ease, filter .12s ease;
        }
        .fab svg { width: 22px; height: 22px; display: block; }
        .fab:hover { filter: brightness(1.12); }
        .fab:active { transform: scale(.94); }
        .fab.cargando { opacity: .5; }

        /* ===== Hoja inferior: todos los controles en la zona del pulgar ===== */
        .sheet {
            position: fixed; z-index: 1050;
            left: 0; right: 0; bottom: 0;
            background: var(--mat);
            backdrop-filter: var(--mat-blur); -webkit-backdrop-filter: var(--mat-blur);
            border-top: .5px solid var(--line);
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            box-shadow: 0 -10px 40px rgba(0, 0, 0, .4), var(--hi);
            padding: 6px 16px calc(14px + env(safe-area-inset-bottom));
            padding-left: calc(16px + env(safe-area-inset-left));
            padding-right: calc(16px + env(safe-area-inset-right));
            display: flex; flex-direction: column; gap: 12px;
            max-width: 640px; margin: 0 auto;
            transition: transform .3s cubic-bezier(.32, .72, 0, 1);
        }
        .grabber-zone {
            flex: 0 0 auto; display: flex; justify-content: center;
            padding: 9px 0 7px; margin: -2px 0 -2px; cursor: grab;
            touch-action: none; -webkit-tap-highlight-color: transparent;
        }
        .grabber-zone:active { cursor: grabbing; }
        .grabber {
            width: 36px; height: 5px; border-radius: 3px;
            background: rgba(235, 235, 245, .3); pointer-events: none;
        }
        .sheet-head { display: flex; align-items: center; gap: 10px; }
        .brand { display: flex; align-items: center; gap: 9px; font-weight: 600; font-size: 1rem; letter-spacing: -.02em; }
        .brand .autor { font-weight: 500; font-size: .76rem; color: var(--accent); opacity: .85; }
        .brand .dot {
            width: 9px; height: 9px; border-radius: 50%; flex: 0 0 auto;
            background: #2ecc71; box-shadow: 0 0 0 0 rgba(46, 204, 113, .7);
            animation: pulse 1.8s infinite;
        }
        @@keyframes pulse {
            0%   { box-shadow: 0 0 0 0 rgba(46, 204, 113, .6); }
            70%  { box-shadow: 0 0 0 8px rgba(46, 204, 113, 0); }
            100% { box-shadow: 0 0 0 0 rgba(46, 204, 113, 0); }
        }
        #linkInterurbano {
            margin-left: auto; flex: 0 0 auto;
            background: var(--fill-2); color: var(--accent);
            border: 0; border-radius: 980px; padding: 7px 14px;
            font-weight: 600; font-size: .85rem; letter-spacing: -.01em;
            text-decoration: none; white-space: nowrap;
            transition: background .15s ease;
        }
        #linkInterurbano:hover { background: var(--fill-2-press); }

        .stat { display: flex; align-items: center; gap: 9px; font-size: .85rem; color: var(--muted); }
        .stat b { color: var(--accent); font-variant-numeric: tabular-nums; }
        /* Contador circular estilo reloj: se llena hasta la próxima actualización */
        .contador svg { display: block; transform: rotate(-90deg); flex: 0 0 auto; }
        .ring-track { fill: none; stroke: var(--line); stroke-width: 3; }
        .ring-prog {
            fill: none; stroke: var(--accent); stroke-width: 3; stroke-linecap: round;
            transition: stroke-dashoffset .08s linear;
        }

        /* Leyenda de sentidos (ida/vuelta), ahora dentro de la hoja */
        .leyenda { display: none; border-top: 1px solid var(--line); padding-top: 9px; }
        .leyenda.visible { display: block; }
        .leyenda h4 { margin: 0 0 6px; font-size: .7rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
        .ley-item { display: flex; align-items: center; gap: 8px; padding: 2px 0; font-size: .85rem; }
        .ley-sw { width: 12px; height: 12px; border-radius: 50%; border: 1.5px solid #fff; flex: 0 0 auto; }

        /* Botonera: cada control ocupa su propia fila */
        .acciones { display: flex; flex-direction: column; gap: 8px; }
        .acciones button {
            width: 100%; min-height: 44px;
            border-radius: 12px; font-weight: 600; font-size: .98rem; letter-spacing: -.01em;
            cursor: pointer; border: 0; background: var(--fill-2); color: var(--txt);
            transition: background .15s ease, transform .12s ease;
        }
        .acciones button:hover { background: var(--fill-2-press); }
        .acciones button:active { transform: scale(.99); }

        /* Interruptor estilo iOS para "Ver todos" */
        .toggle-row {
            display: flex; align-items: center; justify-content: space-between;
            gap: 12px; padding: 0 8px 0 14px; text-align: left;
        }
        .toggle-label { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .switch {
            flex: 0 0 auto; position: relative;
            width: 51px; height: 31px; border-radius: 999px;
            background: rgba(120, 120, 128, .32); transition: background .25s ease;
        }
        .switch .knob {
            position: absolute; top: 2px; left: 2px;
            width: 27px; height: 27px; border-radius: 50%; background: #fff;
            box-shadow: 0 2px 5px rgba(0, 0, 0, .35), 0 0 1px rgba(0, 0, 0, .25);
            transition: transform .25s cubic-bezier(.32, .72, 0, 1);
        }
        .toggle-row.on .switch { background: var(--accent); }
        .toggle-row.on .switch .knob { transform: translateX(20px); }

        /* Oculta el panel deslizándolo hacia abajo; queda un asomo para volver a abrirlo */
        .sheet.hidden { transform: translateY(calc(100% - 26px)); }

        /* Popups de Leaflet */
        .leaflet-popup-content { font-size: .88rem; line-height: 1.5; }
        .pill {
            display: inline-block; background: var(--accent-2); color: #fff;
            border-radius: 6px; padding: 1px 8px; font-weight: 700; margin-right: 4px;
        }

        /* Oculta el branding/anuncios que somee inyecta en el plan gratuito */
        center,
        a[href*="somee.com"],
        iframe[src*="somee"],
        [id*="WholeInsert"],
        [class*="WholeInsert"] { display: none !important; }

        /* Accesibilidad: foco visible por teclado y respeto por "menos movimiento" */
        :focus-visible {
            outline: 2px solid var(--accent-2);
            outline-offset: 2px;
            border-radius: 8px;
        }
        @@media (prefers-reduced-motion: reduce) {
            * { animation-duration: .001ms !important; transition-duration: .001ms !important; }
            .brand .dot { animation: none; }
        }

        /* ===== Escritorio / tablet: la hoja se vuelve una tarjeta flotante ===== */
        @@media (min-width: 680px) {
            .topbar { left: calc(12px + env(safe-area-inset-left)); right: auto; margin: 0; }
            .sheet {
                left: calc(12px + env(safe-area-inset-left)); right: auto;
                bottom: calc(12px + env(safe-area-inset-bottom));
                width: 360px; border-radius: var(--radius); border: 1px solid var(--line);
            }
        }
    </style>
</head>
<body>
    <!-- El mapa ocupa toda la pantalla; la UI flota encima -->
    <div id="map"></div>

    <!-- Buscador flotante -->
    <div id="topbar" class="topbar">
        <div class="buscador">
            <div class="searchbar">
                <span class="lupa" aria-hidden="true"></span>
                <input type="text" id="filtro" placeholder="Buscá tu línea o destino: 149 ADUANA…"
                       autocomplete="off" role="combobox" aria-expanded="false" aria-autocomplete="list"
                       aria-label="Buscar línea o destino" />
                <button id="btnClear" class="clear" type="button" aria-label="Borrar búsqueda" hidden>
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" fill="currentColor" />
                        <path d="M8.5 8.5l7 7M15.5 8.5l-7 7" stroke="#1c1c1e" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </button>
                <button id="btnBuscar">Buscar</button>
            </div>
            <div id="sugerencias" class="sugerencias"></div>
        </div>
    </div>

    <!-- Banner de error (lo muestra el JS) -->
    <div id="error" role="alert"></div>

    <!-- FAB: centrar el mapa en mi ubicación -->
    <button id="fab" class="fab" type="button" aria-label="Centrar el mapa en mi ubicación" title="Mi ubicación">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21.3 2.7a1 1 0 0 0-1.06-.23l-16 6.13a1 1 0 0 0 .06 1.88l6.34 2.05 2.05 6.34a1 1 0 0 0 1.88.06l6.13-16a1 1 0 0 0-.4-1.23l-.04-.03z" />
        </svg>
    </button>

    <!-- Hoja inferior: controles al alcance del pulgar -->
    <div id="sheet" class="sheet">
        <div class="grabber-zone" id="grabber" role="button" tabindex="0" aria-expanded="true" aria-label="Deslizá para ocultar o mostrar el panel">
            <span class="grabber"></span>
        </div>
        <div class="sheet-head">
            <div class="brand"><span class="dot"></span>🚌 Bus en Vivo · Montevideo<span class="autor">by Lcorbo</span></div>
            <a id="linkInterurbano" href="/Home/Interurbano" title="Horarios interurbanos">Interurbano</a>
        </div>
        <div class="stat">
            <span class="contador" id="contador" title="Próxima actualización">
                <svg width="26" height="26" viewBox="0 0 26 26">
                    <circle class="ring-track" cx="13" cy="13" r="9"></circle>
                    <circle class="ring-prog" id="ringProg" cx="13" cy="13" r="9"></circle>
                </svg>
            </span>
            <span><b id="count">0</b> ómnibus · cada <b>@refresco</b>s · <span id="reloj">—</span></span>
        </div>
        <div id="leyenda" class="leyenda"></div>
        <div class="acciones">
            <button id="btnTodos" class="toggle-row" type="button" role="switch" aria-checked="false">
                <span class="toggle-label">Ver todos los ómnibus</span>
                <span class="switch" aria-hidden="true"><span class="knob"></span></span>
            </button>
            <button id="btnDejarSeguir" type="button" style="display:none">Dejar de seguir</button>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script>
        // --- Configuración inyectada desde appsettings.json ---
        const CFG = {
            wmsUrl:   "@wmsUrl",
            wmsLayer: "@wmsLayer",
            centro:   [@centroLat, @centroLng],
            zoom:     @zoom,
            refresco: @refresco * 1000
        };

        // --- Mapa ---
        const map = L.map('map', { zoomControl: true }).setView(CFG.centro, CFG.zoom);

        // Capa base por DEFECTO: mapa de calles simple y limpio (CARTO Voyager).
        // Sin saturar como OSM; estilo cercano al de Google/Apple Maps.
        const cartoAttr = '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · © <a href="https://carto.com/attributions">CARTO</a>';
        const mapaSimple = L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
            maxZoom: 20, subdomains: 'abcd', detectRetina: true, attribution: cartoAttr
        }).addTo(map);

        // Variante oscura, a juego con el tema (CARTO Dark Matter).
        const mapaOscuro = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            maxZoom: 20, subdomains: 'abcd', detectRetina: true, attribution: cartoAttr
        });

        // OpenStreetMap clásico (más detalle, queda como opción).
        const osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19, attribution: '© OpenStreetMap'
        });

        // Cartografía oficial de Montevideo (GeoServer WMS de la IM)
        const cartoMvd = L.tileLayer.wms(CFG.wmsUrl, {
            layers: CFG.wmsLayer,
            format: 'image/png',
            transparent: false,
            version: '1.3.0',
            attribution: 'Intendencia de Montevideo · STM'
        });

        // Satélite (Esri World Imagery)
        const satelite = L.tileLayer(
            'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
            { maxZoom: 19, attribution: 'Tiles © Esri — Source: Esri, Maxar, Earthstar Geographics' }
        );

        // Overlays (se llenan al buscar una línea). Son capas apagables con checkbox.
        const capaParadas = L.layerGroup().addTo(map);
        const capaRecorridos = L.layerGroup().addTo(map);

        // Selector de capas (arriba a la derecha): bases + overlays (paradas y recorrido).
        L.control.layers(
            {
                'Mapa simple': mapaSimple,
                'Mapa oscuro': mapaOscuro,
                'OpenStreetMap': osm,
                'Cartografía Montevideo': cartoMvd,
                'Satélite': satelite
            },
            {
                'Paradas de la línea': capaParadas,
                'Recorrido (sentido)': capaRecorridos
            },
            { collapsed: true }
        ).addTo(map);

        // --- Fix de redimensionado ---
        // Leaflet calcula su tamaño una sola vez; si el contenedor cambia (resize de ventana,
        // header que se reacomoda, etc.) los tiles quedan grises/desalineados. invalidateSize()
        // le avisa del nuevo tamaño. Se llama con debounce ante cualquier cambio.
        let resizeRaf = null;
        function ajustarMapa() {
            if (resizeRaf) cancelAnimationFrame(resizeRaf);
            resizeRaf = requestAnimationFrame(() => map.invalidateSize({ animate: false }));
        }
        window.addEventListener('resize', ajustarMapa);
        window.addEventListener('orientationchange', ajustarMapa);
        if (window.ResizeObserver) {
            new ResizeObserver(ajustarMapa).observe(document.getElementById('map'));
        }
        // Reajuste tras el primer render (cuando el layout ya se asentó).
        map.whenReady(() => setTimeout(ajustarMapa, 150));

        // --- Marcadores ---
        const capaBuses = L.layerGroup().addTo(map);
        const errorBox = document.getElementById('error');

        // --- Seguimiento de un bus (lo mantiene centrado en cada refresco) ---
        let busSeguido = null;   // id del bus que estamos siguiendo (o null)
        const btnDejarSeguir = document.getElementById('btnDejarSeguir');
        function setSeguido(id) {
            busSeguido = id;
            btnDejarSeguir.style.display = id ? '' : 'none';
        }
        btnDejarSeguir.addEventListener('click', () => setSeguido(null));
        // Click en el mapa vacío (no sobre un bus) deja de seguir.
        map.on('click', () => setSeguido(null));

        function escapeHtml(s) {
            return (s || '').replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
        }

        function iconoBus(linea, destino, velocidad, color) {
            const numero = linea || '?';
            // Ajusta el ancho del círculo según la cantidad de caracteres (ej. "155" vs "CE1").
            const ancho = Math.max(30, 16 + numero.length * 8);
            const colorBus = color || '#1f6feb';

            // Un SOLO círculo con el número de línea (coloreado por sentido). Sin badge encima
            // para no tapar el número.
            const circulo = `<div style="background:${colorBus};color:#fff;border:2px solid #fff;
                        width:${ancho}px;height:30px;border-radius:50%;flex:0 0 auto;
                        display:flex;align-items:center;justify-content:center;
                        font:700 13px system-ui;box-shadow:0 1px 5px rgba(0,0,0,.55)">${escapeHtml(numero)}</div>`;

            // Velocidad: SOLO se muestra si es > 0. Muchos buses (sobre todo de otros subsistemas)
            // reportan 0 aunque se muevan; en ese caso se oculta para no mostrar "0 km/h" engañoso.
            const vel = Number.isFinite(velocidad) ? velocidad : 0;
            const colorVel = vel <= 20 ? '#f5a623' : '#2ecc71'; // lento / rápido
            const chipVel = vel > 0
                ? `<span style="display:inline-block;margin-left:6px;padding:0 5px;border-radius:6px;
                        background:${colorVel};color:#fff;font:700 10px system-ui">${vel} km/h</span>`
                : '';

            // Etiqueta con el SENTIDO (+ velocidad si la hay), por FUERA del círculo.
            const contenido = (destino ? `→ ${escapeHtml(destino)}` : '') + chipVel;
            const etiqueta = contenido
                ? `<div style="background:rgba(255,255,255,.92);color:#111;border-left:4px solid ${colorBus};
                        border-radius:6px;padding:2px 7px;font:600 11px system-ui;white-space:nowrap;
                        box-shadow:0 1px 4px rgba(0,0,0,.35)">${contenido}</div>`
                : '';
            return L.divIcon({
                className: '',
                html: `<div style="display:flex;align-items:center;gap:4px">${circulo}${etiqueta}</div>`,
                iconSize: [ancho, 30],
                iconAnchor: [ancho / 2, 15]  // el punto queda en el centro del círculo; la etiqueta sobresale a la derecha
            });
        }

        // Si está en true, "Ver todos" fuerza traer todas las líneas aunque no haya filtro.
        let mostrarTodos = false;

        // --- Colores por SENTIDO (ida / vuelta): cada destino distinto recibe un color ---
        const PALETA = ['#1f6feb', '#8957e5', '#e5484d', '#16a3a3', '#f5a623', '#d6409f', '#2ecc71', '#0aa'];
        let mapaColores = {};   // destino -> color

        function asignarColores(destinos) {
            // Orden alfabético -> asignación estable (no cambia el color entre refrescos).
            const distintos = [...new Set(destinos.filter(Boolean))].sort();
            mapaColores = {};
            distintos.forEach((d, i) => { mapaColores[d] = PALETA[i % PALETA.length]; });
        }
        const colorDestino = (d) => mapaColores[d] || '#1f6feb';

        // Dibuja/oculta la leyenda de sentidos (cada destino con su color).
        function actualizarLeyenda(mostrar) {
            const box = document.getElementById('leyenda');
            const destinos = Object.keys(mapaColores);
            if (!mostrar || destinos.length === 0) { box.classList.remove('visible'); box.innerHTML = ''; return; }
            box.innerHTML = '<h4>Sentido</h4>' + destinos.map(d =>
                `<div class="ley-item"><span class="ley-sw" style="background:${mapaColores[d]}"></span>→ ${escapeHtml(d)}</div>`
            ).join('');
            box.classList.add('visible');
        }

        // --- DataProvider de líneas (número + texto): alimenta el autocompletado y la resolución ---
        let LINEAS = [];

        async function cargarLineas() {
            try {
                const r = await fetch('/api/bus/lineas');
                const d = await r.json();
                if (d.ok) LINEAS = d.lineas;   // alimenta el autocompletado (combobox)
            } catch { /* si falla, el filtro de texto igual funciona */ }
        }

        // Normaliza: mayúsculas y sin acentos, para comparar sin importar tildes ni mayúsculas.
        function normalizar(s) {
            return (s || '').toString().normalize('NFD').replace(/[̀-ͯ]/g, '').toUpperCase();
        }

        // Devuelve el código de línea si el token coincide EXACTO con una línea conocida; si no, null.
        function esLineaExacta(token) {
            const t = normalizar(token);
            const m = LINEAS.find(l => normalizar(l.linea) === t);
            return m ? m.linea : null;
        }

        // Separa lo escrito en: líneas (números/códigos) y texto libre (destino/sublínea).
        // Ej: "149 ADUANA" -> { lineas:["149"], texto:"ADUANA" }
        function parseConsulta(raw) {
            const palabras = raw.split(/[\s,]+/).filter(Boolean);
            const lineas = [];
            const texto = [];
            for (const p of palabras) {
                const ln = esLineaExacta(p);
                if (ln) { if (!lineas.includes(ln)) lineas.push(ln); }
                else {
                    const limpio = p.replace(/[^0-9a-záéíóúñ]/gi, ''); // descarta · - etc.
                    if (limpio) texto.push(limpio);
                }
            }
            return { lineas, texto: texto.join(' ').trim() };
        }

        // Filtra (visualmente) los buses dejando solo los de texto MÁS similar al buscado.
        function filtrarPorTexto(buses, texto) {
            const palabras = normalizar(texto).split(/\s+/).filter(Boolean);
            if (!palabras.length) return buses;
            const puntaje = (b) => {
                const campo = normalizar([b.linea, b.sublinea, b.destino, b.tipoLinea].join(' '));
                let s = 0;
                for (const w of palabras) if (campo.includes(w)) s++;
                return s;
            };
            const conPuntaje = buses.map(b => ({ b, s: puntaje(b) }));
            const max = conPuntaje.reduce((m, x) => Math.max(m, x.s), 0);
            if (max === 0) return [];                 // nada se parece al texto buscado
            return conPuntaje.filter(x => x.s === max).map(x => x.b);  // solo los más similares
        }

        // --- Paradas de la línea buscada (se cargan una vez por cambio de línea) ---
        let paradasKey = null;   // recuerda qué líneas se dibujaron, para no recargar cada 2 s
        async function actualizarParadas(lineas) {
            const key = lineas.slice().sort().join(',');
            if (key === paradasKey) return;     // ya están dibujadas estas paradas
            paradasKey = key;
            capaParadas.clearLayers();
            if (!lineas.length) return;
            try {
                const r = await fetch('/api/bus/paradas?lineas=' + encodeURIComponent(lineas.join(',')));
                const d = await r.json();
                if (!d.ok || paradasKey !== key) return;   // cambió la búsqueda mientras cargaba
                for (const p of d.paradas) {
                    L.circleMarker([p.lat, p.lng], {
                        radius: 4, color: '#e5484d', weight: 2, fillColor: '#fff', fillOpacity: 1
                    })
                        .bindPopup(`🚏 <b>Parada</b><br>${escapeHtml(p.calle || '')}` +
                            `${p.esquina ? ' y ' + escapeHtml(p.esquina) : ''}`)
                        .addTo(capaParadas);
                }
            } catch { /* las paradas son opcionales: si fallan, no rompemos el mapa */ }
        }

        // --- Recorrido (ruta) de las variantes que tienen buses activos ---
        // Recibe un mapa { varianteCodigo: destino } y traza una polilínea por variante,
        // coloreada según el sentido (mismo color que el bus). Se cachea por set de variantes.
        let recorridosKey = null;
        async function actualizarRecorridos(varianteDestino) {
            const variantes = Object.keys(varianteDestino).filter(v => v && v !== '0');
            const key = variantes.slice().sort().join(',');
            if (key === recorridosKey) return;
            recorridosKey = key;
            capaRecorridos.clearLayers();
            if (!variantes.length) return;
            try {
                const r = await fetch('/api/bus/recorridos?variantes=' + encodeURIComponent(variantes.join(',')));
                const d = await r.json();
                if (!d.ok || recorridosKey !== key) return;   // cambió mientras cargaba
                for (const rec of d.recorridos) {
                    if (!rec.paradas || rec.paradas.length < 2) continue;
                    const color = colorDestino(varianteDestino[rec.variante]);
                    const pts = rec.paradas.map(p => [p.lat, p.lng]);
                    // Halo oscuro debajo + línea de color encima, para que resalte sobre el mapa.
                    L.polyline(pts, { color: '#000', weight: 7, opacity: .25 }).addTo(capaRecorridos);
                    L.polyline(pts, { color, weight: 4, opacity: .9 })
                        .bindPopup(`🧭 <b>Recorrido →</b> ${escapeHtml(varianteDestino[rec.variante] || '')}`)
                        .addTo(capaRecorridos);
                }
            } catch { /* el recorrido es opcional: si falla, no rompemos el mapa */ }
        }

        async function refrescar() {
            const raw = document.getElementById('filtro').value.trim();

            // Por defecto no se trae ningún ómnibus hasta que el usuario filtre.
            if (!raw && !mostrarTodos) {
                capaBuses.clearLayers();
                actualizarParadas([]);
                actualizarRecorridos({});
                mapaColores = {}; actualizarLeyenda(false);
                document.getElementById('count').textContent = '0';
                document.getElementById('reloj').textContent = 'elegí o escribí una línea o destino';
                errorBox.style.display = 'none';
                return;
            }

            const q = parseConsulta(raw);
            // El API solo filtra por número de línea. Si hay líneas, pedimos esas;
            // si solo hay texto, traemos todas y filtramos por texto del lado del cliente.
            let url = '/api/bus/posiciones';
            if (!mostrarTodos && q.lineas.length) {
                url += '?lineas=' + encodeURIComponent(q.lineas.join(','));
            }

            // Paradas: solo cuando hay línea(s) concreta(s) (no en "Ver todos" ni búsqueda solo por texto).
            actualizarParadas(mostrarTodos ? [] : q.lineas);

            try {
                const r = await fetch(url);
                const data = await r.json();
                if (!data.ok) throw new Error(data.error || 'Error desconocido');

                // Filtrado visual por texto (destino/sublínea) si se especificó.
                let buses = data.buses;
                if (!mostrarTodos && q.texto) buses = filtrarPorTexto(buses, q.texto);

                // Sentido (ida/vuelta): coloreamos por destino cuando hay línea(s) concreta(s).
                const colorearSentido = !mostrarTodos && q.lineas.length > 0;
                if (colorearSentido) asignarColores(buses.map(b => b.destino));
                else mapaColores = {};

                capaBuses.clearLayers();
                let seguidoAhora = null;   // bus seguido encontrado en esta tanda (para recentrar)
                for (const b of buses) {
                    const color = colorearSentido ? colorDestino(b.destino) : '#1f6feb';
                    const idBus = b.id || `${b.codigoBus}-${b.empresa}`;
                    const m = L.marker([b.lat, b.lng], { icon: iconoBus(b.linea, b.destino, b.velocidad, color) })
                        .bindPopup(
                            `<b><span class="pill" style="background:${color}">${b.linea ?? '?'}</span></b>` +
                            `${b.sublinea ?? ''}<br>` +
                            `🧭 <b>Sentido →</b> ${b.destino ?? '—'}<br>` +
                            `🌐 <b>Subsistema:</b> ${b.subsistema ?? '—'}<br>` +
                            `⚡ <b>Velocidad:</b> ${b.velocidad > 0 ? b.velocidad + ' km/h' : 'sin dato'}<br>` +
                            `🚍 <b>Coche:</b> ${b.codigoBus} (empresa ${b.empresa})`
                        )
                        .addTo(capaBuses);
                    // Click sobre el bus: empezamos a seguirlo y lo centramos.
                    m.on('click', () => { setSeguido(idBus); map.panTo([b.lat, b.lng], { animate: true }); });
                    if (busSeguido && idBus === busSeguido) seguidoAhora = b;
                }

                // Si estamos siguiendo un bus, lo mantenemos centrado en su nueva posición.
                if (seguidoAhora) map.panTo([seguidoAhora.lat, seguidoAhora.lng], { animate: true });

                // Recorrido (ruta) por sentido: una traza por cada variante que tiene buses activos.
                const varianteDestino = {};
                if (colorearSentido) {
                    for (const b of buses) if (b.variante) varianteDestino[b.variante] = b.destino;
                }
                actualizarRecorridos(varianteDestino);

                actualizarLeyenda(colorearSentido);
                document.getElementById('count').textContent = buses.length;
                document.getElementById('reloj').textContent = (q.texto && buses.length === 0)
                    ? `sin coincidencias para «${q.texto}»`
                    : new Date().toLocaleTimeString('es-UY');
                errorBox.style.display = 'none';
            } catch (e) {
                errorBox.textContent = '⚠ No se pudo obtener la posición de los ómnibus: ' + e.message;
                errorBox.style.display = 'block';
            }
        }

        // --- Eventos ---
        const inputFiltro = document.getElementById('filtro');
        const btnTodos = document.getElementById('btnTodos');
        const btnClear = document.getElementById('btnClear');

        // Muestra la × solo cuando hay texto que borrar.
        function sincronizarClear() { btnClear.hidden = inputFiltro.value.length === 0; }

        // Refleja el estado del interruptor "Ver todos".
        function sincronizarTodos() {
            btnTodos.classList.toggle('on', mostrarTodos);
            btnTodos.setAttribute('aria-checked', mostrarTodos ? 'true' : 'false');
        }

        function buscar() { cerrarSug(); mostrarTodos = false; sincronizarTodos(); sincronizarClear(); refrescar(); }
        document.getElementById('btnBuscar').addEventListener('click', buscar);

        // "Ver todos" como interruptor: lo prende y lo apaga.
        btnTodos.addEventListener('click', () => {
            mostrarTodos = !mostrarTodos;
            if (mostrarTodos) { inputFiltro.value = ''; cerrarSug(); sincronizarClear(); }
            sincronizarTodos();
            refrescar();
        });

        // × del buscador: borra el texto, vuelve el foco al input y refresca.
        btnClear.addEventListener('click', () => {
            inputFiltro.value = '';
            sincronizarClear();
            cerrarSug();
            inputFiltro.focus();
            mostrarTodos = false; sincronizarTodos();
            refrescar();
        });

        // ---- Autocompletado tipo combobox (desplegable bajo el input) ----
        const cajaSug = document.getElementById('sugerencias');
        let sugItems = [];      // líneas mostradas ahora
        let sugActivo = -1;     // índice resaltado (teclado)

        // Devuelve el "término" que se está escribiendo (después de la última coma).
        function terminoActual() {
            const partes = inputFiltro.value.split(',');
            return partes[partes.length - 1].trim();
        }

        function mostrarSugerencias() {
            const term = normalizar(terminoActual());
            if (!term) { cerrarSug(); return; }
            const res = LINEAS.filter(l =>
                normalizar(l.linea).includes(term) || normalizar(l.texto).includes(term));
            // Primero las líneas cuyo número empieza con lo tipeado.
            res.sort((a, b) =>
                (normalizar(a.linea).startsWith(term) ? 0 : 1) -
                (normalizar(b.linea).startsWith(term) ? 0 : 1));
            sugItems = res.slice(0, 40);
            sugActivo = -1;
            if (!sugItems.length) { cerrarSug(); return; }
            cajaSug.innerHTML = sugItems.map((l, i) => {
                // Etiqueta del subsistema cuando no es Montevideo (Canelones, Metropolitano, …).
                const sub = l.subsistema && l.subsistema !== 'Montevideo'
                    ? ` <span class="sub-tag">${escapeHtml(l.subsistema)}</span>` : '';
                return `<div class="sug-item" data-i="${i}"><span class="num">${escapeHtml(l.linea)}</span>${escapeHtml(l.texto || '')}${sub}</div>`;
            }).join('');
            cajaSug.classList.add('abierto');
            inputFiltro.setAttribute('aria-expanded', 'true');
        }

        function cerrarSug() {
            cajaSug.classList.remove('abierto');
            cajaSug.innerHTML = '';
            sugItems = []; sugActivo = -1;
            inputFiltro.setAttribute('aria-expanded', 'false');
        }

        function resaltar(i) {
            sugActivo = i;
            [...cajaSug.children].forEach((el, idx) => el.classList.toggle('activo', idx === i));
            const el = cajaSug.children[i];
            if (el) el.scrollIntoView({ block: 'nearest' });
        }

        function elegirSug(i) {
            const l = sugItems[i];
            if (!l) return;
            // Reemplaza el último término (respeta lo que haya antes de la coma).
            const partes = inputFiltro.value.split(',');
            partes[partes.length - 1] = (partes.length > 1 ? ' ' : '') +
                (l.texto ? `${l.linea} ${l.texto}` : l.linea);
            inputFiltro.value = partes.join(',');
            buscar();
            inputFiltro.focus();
        }

        inputFiltro.addEventListener('input', () => { sincronizarClear(); mostrarSugerencias(); });
        inputFiltro.addEventListener('focus', () => { if (terminoActual()) mostrarSugerencias(); });
        inputFiltro.addEventListener('keydown', (e) => {
            const abierto = cajaSug.classList.contains('abierto');
            if (e.key === 'ArrowDown' && abierto) { e.preventDefault(); resaltar(Math.min(sugActivo + 1, sugItems.length - 1)); }
            else if (e.key === 'ArrowUp' && abierto) { e.preventDefault(); resaltar(Math.max(sugActivo - 1, 0)); }
            else if (e.key === 'Enter') {
                e.preventDefault();
                if (abierto && sugActivo >= 0) elegirSug(sugActivo);
                else buscar();
            }
            else if (e.key === 'Escape') { cerrarSug(); }
        });
        // mousedown (no click) para que se ejecute antes del blur del input.
        cajaSug.addEventListener('mousedown', (e) => {
            const item = e.target.closest('.sug-item');
            if (item) { e.preventDefault(); elegirSug(+item.dataset.i); }
        });
        inputFiltro.addEventListener('blur', () => setTimeout(cerrarSug, 150));

        // ¿Hay algo que actualizar? (cualquier consulta escrita o "Ver todos")
        function hayActividad() {
            return mostrarTodos || inputFiltro.value.trim().length > 0;
        }

        // --- Contador circular: se llena en CFG.refresco y dispara la actualización ---
        const ringProg = document.getElementById('ringProg');
        const CIRC = 2 * Math.PI * 9;                 // circunferencia (r = 9)
        ringProg.style.strokeDasharray = CIRC;
        ringProg.style.strokeDashoffset = CIRC;       // arranca vacío

        let inicioCiclo = performance.now();
        function tick(now) {
            if (hayActividad()) {
                const frac = Math.min((now - inicioCiclo) / CFG.refresco, 1);
                ringProg.style.strokeDashoffset = CIRC * (1 - frac);  // se va llenando
                if (frac >= 1) { inicioCiclo = now; refrescar(); }     // lleno -> actualiza
            } else {
                ringProg.style.strokeDashoffset = CIRC;               // inactivo: vacío
                inicioCiclo = now;
            }
            requestAnimationFrame(tick);
        }

        // --- Mi ubicación (FAB): centra el mapa donde está el usuario ---
        const fab = document.getElementById('fab');
        let marcadorYo = null;
        fab.addEventListener('click', () => {
            if (!navigator.geolocation) {
                errorBox.textContent = '⚠ Tu navegador no permite compartir la ubicación.';
                errorBox.style.display = 'block';
                return;
            }
            fab.classList.add('cargando');
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    fab.classList.remove('cargando');
                    const ll = [pos.coords.latitude, pos.coords.longitude];
                    if (marcadorYo) marcadorYo.setLatLng(ll);
                    else {
                        marcadorYo = L.circleMarker(ll, {
                            radius: 7, color: '#fff', weight: 2, fillColor: '#1f6feb', fillOpacity: 1
                        }).addTo(map).bindPopup('📍 Estás acá');
                    }
                    map.setView(ll, Math.max(map.getZoom(), 15), { animate: true });
                },
                () => {
                    fab.classList.remove('cargando');
                    errorBox.textContent = '⚠ No pudimos obtener tu ubicación. Revisá los permisos.';
                    errorBox.style.display = 'block';
                },
                { enableHighAccuracy: true, timeout: 8000, maximumAge: 30000 }
            );
        });

        // --- Hoja inferior arrastrable (estilo iOS): deslizá hacia abajo para ocultar ---
        const sheet = document.getElementById('sheet');
        const grabber = document.getElementById('grabber');
        const PEEK = 26;                 // px del panel que quedan visibles al ocultarlo
        let sheetHidden = false;
        let drag = null;                 // estado del arrastre en curso

        function offsetOculto() { return Math.max(sheet.offsetHeight - PEEK, 0); }

        // Publica el alto efectivo como --sheet-h: el FAB y la atribución de Leaflet
        // se acomodan por encima del panel sin números mágicos.
        function publicarAltura() {
            const h = sheetHidden ? PEEK : sheet.offsetHeight;
            document.documentElement.style.setProperty('--sheet-h', h + 'px');
        }

        function setHidden(h) {
            sheetHidden = h;
            sheet.style.transform = '';              // que mande la clase CSS
            sheet.classList.toggle('hidden', h);
            grabber.setAttribute('aria-expanded', h ? 'false' : 'true');
            publicarAltura();
        }

        function onDown(e) {
            drag = { y: e.clientY, base: sheetHidden ? offsetOculto() : 0, moved: 0 };
            sheet.style.transition = 'none';         // sigue el dedo sin lag
            try { grabber.setPointerCapture(e.pointerId); } catch (_) { }
        }
        function onMove(e) {
            if (!drag) return;
            const dy = e.clientY - drag.y;
            drag.moved = dy;
            let t = drag.base + dy;
            const max = offsetOculto();
            if (t < 0) t *= .3;                      // resistencia al pasarse hacia arriba
            else if (t > max) t = max + (t - max) * .3;
            sheet.style.transform = `translateY(${t}px)`;
        }
        function onUp() {
            if (!drag) return;
            const dy = drag.moved;
            drag = null;
            sheet.style.transition = '';
            sheet.style.transform = '';
            if (Math.abs(dy) < 6) { setHidden(!sheetHidden); return; }   // toque: alterna
            if (sheetHidden) setHidden(dy >= -40);                       // arrastrar arriba abre
            else setHidden(dy > 70);                                     // arrastrar abajo oculta
        }

        grabber.addEventListener('pointerdown', onDown);
        grabber.addEventListener('pointermove', onMove);
        grabber.addEventListener('pointerup', onUp);
        grabber.addEventListener('pointercancel', onUp);
        grabber.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); setHidden(!sheetHidden); }
        });

        if (window.ResizeObserver) new ResizeObserver(publicarAltura).observe(sheet);
        window.addEventListener('orientationchange', () => setTimeout(publicarAltura, 200));
        publicarAltura();

        // Carga el autocompletado; al terminar, admite enlaces directos (#155 o #149 ADUANA).
        cargarLineas().then(() => {
            if (location.hash.length > 1) {
                inputFiltro.value = decodeURIComponent(location.hash.slice(1));
                buscar();
            }
        });
        refrescar();
        requestAnimationFrame(tick);
    </script>
</body>
</html>
